USE_LOCAL_DB=false
LOCAL_MONGO_URI=mongodb://localhost:27017/humtum-bar-pos
CLOUD_MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/humtum-bar-pos

PORT=3000
NODE_ENV=production
RESTAURANT_NAME=HumTum
REPORT_CRON=55 23 * * *

# Frontend API URL for browser requests in production.
# Keep empty when the frontend is served by the same Express server.
VITE_API_URL=

# Redis cache
REDIS_URL=redis://localhost:6379

# Mail settings used as defaults when nothing is saved from the Settings page.
GMAIL_SENDER=
GMAIL_APP_PASSWORD=
ADMIN_EMAIL=

# Optional custom SMTP server instead of Gmail
SMTP_HOST=
SMTP_USER=
SMTP_PORT=587
SMTP_SECURE=false
