USE_LOCAL_DB=false
LOCAL_MONGO_URI=mongodb://localhost:27017/humtum-bar-pos
CLOUD_MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=HUMTUMBAR
PORT=3000
RESTAURANT_NAME=HumTum

# Gmail (used for daily reports + forgot password OTP)
GMAIL_SENDER=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
ADMIN_EMAIL=owner@example.com

# Frontend API URL (leave empty in production — uses window.location.origin)
# VITE_API_URL=

# Cron schedule for daily report (default: 11:55 PM IST)
REPORT_CRON=55 23 * * *

# Upstash Redis (for caching)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# JWT Secret (change this in production!)
JWT_SECRET=change-this-to-a-random-secret-key-in-production
